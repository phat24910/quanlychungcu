{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist/out-tsc",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "sourceMap": true,
    "declaration": false,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "target": "es2017",
    "module": "es2020",
    "lib": [
      "es2018",
      "dom"
    ],
    "paths": {
      "@app/*": [
        "apps/resident-portal/src/app/*"
      ],
      "@env/*": [
        "apps/resident-portal/src/environments/*"
      ],
      "@core/auth/data-access": [
        "libs/core/auth/data-access/src/lib/index.ts"
      ],
      "@core/auth/data-access/*": [
        "libs/core/auth/data-access/src/lib/*"
      ],
      "@core/guards": [
        "libs/core/guards/src/lib/index.ts"
      ],
      "@core/interceptors": [
        "libs/core/interceptors/src/lib/index.ts"
      ],
      "@features/auth/feature": [
        "libs/features/auth/feature/src/lib/index.ts"
      ],
      "@features/auth/data-access": [
        "libs/features/auth/data-access/src/lib/index.ts"
      ],
      "@features/dashboard/feature": [
        "libs/features/dashboard/feature/src/lib/index.ts"
      ],
      "@features/dashboard/data-access": [
        "libs/features/dashboard/data-access/src/lib/index.ts"
      ],
      "@features/resident/feature": [
        "libs/features/resident/feature/src/lib/index.ts"
      ],
      "@features/profile/feature": [
        "libs/features/profile/feature/src/lib/index.ts"
      ],
      "@features/profile/data-access": [
        "libs/features/profile/data-access/src/lib/index.ts"
      ],
      "@features/resident/data-access": [
        "libs/features/resident/data-access/src/lib/index.ts"
      ],
      "@shared/ui": [
        "libs/shared/ui/src/lib/index.ts"
      ],
      "@shared/utils": [
        "libs/shared/utils/src/lib/index.ts"
      ],
      "@shared/models": [
        "libs/shared/models/src/lib/index.ts"
      ]
    }
  }
}
